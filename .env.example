# =============================================================================
# IGNITO ACADEMY AMS — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development.
# For production, set these variables in the Vercel dashboard under:
#   Project → Settings → Environment Variables
#
# IMPORTANT: Never commit .env.local or any file containing real secrets.
# =============================================================================


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# The public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# The public anon key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The service-role key (NEVER expose to the browser; used in server-only code)
# Required for: admin operations, Edge Functions, email logging
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─── Application URL ──────────────────────────────────────────────────────────
# The canonical public URL of the deployed Next.js app.
# Used for constructing absolute URLs in payment callback redirects.
# Local:      http://localhost:3000
# Production: https://admissions.ignitoacademy.com
NEXT_PUBLIC_APP_URL=https://admissions.ignitoacademy.com


# ─── Payment Provider Configuration ───────────────────────────────────────────
# CRITICAL: USD SINGLE-CURRENCY ONLY
# All payments must be in USD. No CDF support. No exchange rate conversions.

# Payment provider selection: "pawapay" (production) or "mock" (development)
PAYMENT_PROVIDER=pawapay

# Application fee (hardcoded, USD only)
APPLICATION_FEE_USD=29


# ─── Pawa Pay Payment Gateway (USD Mobile Money for DRC) ──────────────────────
# Obtain from: Pawa Pay Developer Portal → API Keys
# Docs: https://docs.pawapay.io

# Pawa Pay API Key (test or production)
PAWAPAY_API_KEY=<your-pawapay-api-key>

# Pawa Pay API Secret (for webhook signature verification)
PAWAPAY_API_SECRET=<your-pawapay-api-secret>

# Pawa Pay Base URL
# Sandbox: https://api.sandbox.pawapay.io
# Production: https://api.pawapay.io
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# Webhook secret for HMAC-SHA256 signature verification
PAWAPAY_WEBHOOK_SECRET=<your-pawapay-webhook-secret>


# ─── Email — Resend ───────────────────────────────────────────────────────────
# Obtain from: https://resend.com → API Keys → Add API Key
# The key must have "Send Email" permission for the ignitoacademy.com domain.

RESEND_API_KEY=re_<your-resend-api-key>

# The From address used for all outgoing emails.
# Must be verified in Resend → Domains before production use.
FROM_EMAIL=admissions@ignitoacademy.com


# ─── PDF Generation Assets ────────────────────────────────────────────────────
# These URLs are embedded in server-generated PDF letters.
# Host the assets on a reliable CDN or Supabase Storage public bucket.
# The files must be publicly accessible (no auth) since the Edge Function
# fetches them at PDF generation time.

# Ignito Academy logo (PNG, approx 400×100px, white background)
PDF_LOGO_URL=https://<project-ref>.supabase.co/storage/v1/object/public/assets/ignito-logo-pdf.png

# Director's signature (PNG, approx 315×213px, transparent background)
PDF_SIGNATURE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/assets/signature-pdf.png

# Footer line printed at the bottom of every PDF letter
PDF_FOOTER_TEXT=Ignito Academy | En partenariat avec NCC Education (Royaume-Uni) | Kinshasa, RDC


# ─── Application Configuration ────────────────────────────────────────────────
# The active intake year (used for Applicant ID generation: IGN-YYYY-NNNNN)
INTAKE_YEAR=2026


# =============================================================================
# Vercel-specific Notes
# =============================================================================
#
# 1. NEXT_PUBLIC_* variables are inlined at build time.
#    Any change to them requires a fresh deployment.
#
# 2. Server-only variables (no NEXT_PUBLIC_ prefix) are never sent to the browser.
#
# 3. Supabase Edge Functions read environment variables differently:
#    Set them via: supabase secrets set KEY=VALUE
#    Or in: Supabase Dashboard → Edge Functions → Secrets
#    The following secrets must also be set there:
#      - RESEND_API_KEY
#      - FROM_EMAIL
#      - SUPABASE_SERVICE_ROLE_KEY  (auto-available as Deno.env.get('SUPABASE_SERVICE_ROLE_KEY'))
#      - PAWAPAY_API_KEY
#      - PAWAPAY_API_SECRET
#      - PAWAPAY_WEBHOOK_SECRET
#      - PDF_LOGO_URL
#      - PDF_SIGNATURE_URL
#      - PDF_FOOTER_TEXT
#
# 4. Pawa Pay webhook URL to register in Pawa Pay dashboard:
#      https://<project-ref>.supabase.co/functions/v1/payment-webhook
#
# 5. CRITICAL ARCHITECTURAL CONSTRAINTS:
#    - USD SINGLE-CURRENCY ONLY: No CDF, no exchange rates, no currency conversion
#    - OTHM KEYWORD PROHIBITED: Automated scanning blocks any "OTHM" references
#    - SUPABASE AUTH ONLY: No manual password hashing (bcrypt, argon2, etc.)
#    - VIDEO URLs NOT UPLOADS: YouTube/Vimeo URLs only, no video file storage
# =============================================================================
