# =============================================================================
# IGNITO ACADEMY AMS — Local Development Environment Variables
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in the values from your Supabase project dashboard
# 3. NEVER commit .env.local to version control
# =============================================================================

# ─── Supabase Configuration ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon/Public Key (public, safe to expose - RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (PRIVATE - server-side only, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database Direct Connection (for migrations)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Application Configuration ───────────────────────────────────────────────

# Application URL (local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Current intake year
INTAKE_YEAR=2026

# Application fee (USD only)
APPLICATION_FEE_USD=29

# Maximum scholarships per year
MAX_SCHOLARSHIPS_PER_YEAR=20

# ─── Payment Provider Configuration ──────────────────────────────────────────
# CRITICAL: USD single-currency only

# Payment provider: 'pawapay' (production) or 'mock' (development)
PAYMENT_PROVIDER=mock

# Pawa Pay API Credentials (leave empty for mock mode)
PAWAPAY_API_KEY=
PAWAPAY_API_SECRET=
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_WEBHOOK_SECRET=

# ─── Email Service (Resend) ──────────────────────────────────────────────────

# Resend API Key (get from https://resend.com)
RESEND_API_KEY=

# From email address (must be verified in Resend)
FROM_EMAIL=admissions@ignitoacademy.com

# ─── PDF Generation Assets ───────────────────────────────────────────────────

# Logo URL (publicly accessible)
PDF_LOGO_URL=

# Signature URL (publicly accessible)
PDF_SIGNATURE_URL=

# Footer text
PDF_FOOTER_TEXT=Ignito Academy · Portail Admitta · Kinshasa, RDC

# =============================================================================
# CRITICAL ARCHITECTURAL CONSTRAINTS (Non-Negotiable)
# =============================================================================
# 1. USD Single-Currency: No CDF, no exchange rates
# 2. OTHM Keyword Ban: "OTHM" is strictly prohibited
# 3. Supabase Auth ONLY: No manual password hashing (no bcrypt)
# 4. Video URLs Only: YouTube/Vimeo links, no video file uploads
# =============================================================================
