{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "Literal[value=/OT\u0048M/i]",
        "message": "Terme r\u00e9serv\u00e9. Utilisez 'UK Level 3 Foundation Diploma'."
      },
      {
        "selector": "TemplateElement[value.raw=/OT\u0048M/i]",
        "message": "Terme r\u00e9serv\u00e9. Utilisez 'UK Level 3 Foundation Diploma'."
      },
      {
        "selector": "Identifier[name=/OT\u0048M/i]",
        "message": "Terme r\u00e9serv\u00e9 dans les identifiants. Utilisez une autre nomenclature."
      }
    ],
    "react/no-unescaped-entities": "off"
  },
  "overrides": [
    {
      "files": [
        "src/lib/validation/keywords.ts",
        "src/lib/validation/schemas.ts",
        "src/lib/validation/__tests__/**/*.ts",
        "src/__tests__/property-p46-p65-four-pillars.test.ts"
      ],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
  ]
}
