# Supabase Edge Function Secrets — Production Reference
#
# Set these via the Supabase CLI before deploying Edge Functions:
#   supabase secrets set RESEND_API_KEY=re_live_...
#   supabase secrets set FROM_EMAIL=admin@ignitoacademy.com
#   supabase secrets set NOMBA_WEBHOOK_SECRET=<webhook-secret>
#   supabase secrets set PDF_LOGO_URL=https://...
#   supabase secrets set PDF_SIGNATURE_URL=https://...
#   supabase secrets set PDF_FOOTER_TEXT="Ignito Academy | ..."
#
# Or configure in: Supabase Dashboard → Edge Functions → Secrets
#
# SUPABASE_SERVICE_ROLE_KEY is automatically available in Edge Functions
# as Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') — no manual set needed.
#
# List current secrets: supabase secrets list

RESEND_API_KEY=re_<your-resend-api-key>
FROM_EMAIL=admin@ignitoacademy.com
NOMBA_WEBHOOK_SECRET=<your-nomba-webhook-secret>
PDF_LOGO_URL=https://<project-ref>.supabase.co/storage/v1/object/public/assets/ignito-logo-pdf.png
PDF_SIGNATURE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/assets/signature-pdf.png
PDF_FOOTER_TEXT=Ignito Academy | En partenariat avec NCC Education (Royaume-Uni) | Kinshasa, RDC
